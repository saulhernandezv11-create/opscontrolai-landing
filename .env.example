# ============================================================
# OpsControl AI – Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── MongoDB Atlas (free M0 cluster) ─────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/opscontrol?retryWrites=true&w=majority
MONGODB_DB=opscontrol

# ─── Redis (Upstash free tier) ────────────────────────────────
# Get this from: https://upstash.com → Create Redis → Copy "REDIS_URL"
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# ─── OpenAI (direct API, not Azure OpenAI) ────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# gpt-4o-mini recommended ($0.15/1M tokens) – or gpt-4o for higher quality
OPENAI_MODEL=gpt-4o-mini

# ─── Meta WhatsApp Cloud API ──────────────────────────────────
# Generate a random string for the verify token (use: openssl rand -hex 16)
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# App Secret from Meta Developer Console → App → Settings → Basic
META_APP_SECRET=your-meta-app-secret
# System User Access Token (for initial registration; stored per-tenant in DB)
META_API_TOKEN=your-meta-long-lived-token

# ─── Admin API Auth ───────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-signing-key-min-32-chars

# ─── URLs ─────────────────────────────────────────────────────
# Railway URL after deploy (e.g. https://opscontrol-backend.up.railway.app)
API_BASE_URL=https://your-backend.up.railway.app
# Vercel URL after deploy (e.g. https://admin.opscontrolai.com)
ADMIN_DASHBOARD_URL=https://your-admin.vercel.app
